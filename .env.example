# --- Required ---
# Telegram bot token from @BotFather (https://t.me/BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# TMDB API key (free): https://www.themoviedb.org/settings/api
# Either a v3 API key OR a v4 "API Read Access Token" works.
TMDB_API_KEY=

# --- Optional ---
# A default location used when a user hasn't set their own with /setlocation.
# Format: "City, Country"  e.g. "Manila, Philippines" or "Berlin, Germany"
DEFAULT_LOCATION=

# MovieGlu global showtimes API (optional). If set, the bot prints exact
# per-cinema timeslots + booking links INSIDE the chat. Without it, the bot
# still works everywhere via Google Showtimes deep-links.
# Sign up: https://developer.movieglu.com/
MOVIEGLU_API_BASE=https://api-gate2.movieglu.com
MOVIEGLU_CLIENT=
MOVIEGLU_API_KEY=
MOVIEGLU_AUTHORIZATION=
MOVIEGLU_TERRITORY=
MOVIEGLU_API_VERSION=v201
